{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.OpenWeb-Ninja/openwebninja-mcp",
  "description": "Official MCP server for OpenWeb Ninja APIs - 40+ real-time web data and SERP APIs as MCP tools",
  "repository": {
    "url": "https://github.com/OpenWeb-Ninja/openwebninja-mcp",
    "source": "github"
  },
  "websiteUrl": "https://www.openwebninja.com",
  "version": "0.1.1",
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "@openwebninja/mcp-server",
      "version": "0.1.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "OPENWEBNINJA_API_KEY",
          "description": "Your OpenWeb Ninja API key",
          "isRequired": true,
          "isSecret": true,
          "format": "string"
        }
      ]
    }
  ]
}
